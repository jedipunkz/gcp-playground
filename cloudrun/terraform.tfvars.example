# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored.

project_id   = "your-gcp-project-id"
region       = "asia-northeast1"
service_name = "myapp"
environment  = "prod"
domain_name  = "app.gcp-playground.example.com"

# Cloud Run scaling
min_instances = 1
max_instances = 10
cpu_limit     = "1"
memory_limit  = "512Mi"

# GitHub repository for Cloud Build trigger
# Connect the repo in GCP Console before applying:
#   Cloud Build → Triggers → Connect repository
github_owner  = "jedipunkz"
github_repo   = "gcp-playground"
github_branch = "main"

# Cloud Armor rate limiting
cloud_armor_rate_limit_count        = 100
cloud_armor_rate_limit_interval_sec = 60
